---
layout: base.njk
title: Heim
showHero: true
---

{# Split posts into future, regular, and undervegs #}
{% set futurePosts = [] %}
{% set regularPosts = [] %}
{% set undervegsPosts = [] %}

{% for post in posts %}
  {% set hasContent = false %}
  {% for day in post.days %}
    {% if day.images and day.images.length > 0 %}
      {% set hasContent = true %}
    {% endif %}
  {% endfor %}

  {% if post.slug == "tankar-pa-vegen" %}
    {% set undervegsPosts = (undervegsPosts.push(post), undervegsPosts) %}
  {% elif hasContent %}
    {% set regularPosts = (regularPosts.push(post), regularPosts) %}
  {% else %}
    {% set futurePosts = (futurePosts.push(post), futurePosts) %}
  {% endif %}
{% endfor %}

{# Featured: first regular post (newest) #}
{% if regularPosts.length > 0 %}
  {% set feat = regularPosts[0] %}
  {% set firstImage = null %}
  {% for day in feat.days %}
    {% if not firstImage and day.images and day.images.length > 0 %}
      {% set firstImage = day.images[0] %}
    {% endif %}
  {% endfor %}
  {% set firstDay = feat.days | selectattr("date") | first %}
  {% set lastDay = feat.days | selectattr("date") | last %}
  <a href="/{{ feat.slug }}/" class="featured-card">
    {% if firstImage %}
    <img src="{{ firstImage.thumbnail }}" alt="{{ feat.title }}">
    {% else %}
    <div class="featured-placeholder"></div>
    {% endif %}
    <div class="featured-text">
      <span class="featured-badge">Nyaste</span>
      <h2>{{ feat.title }}</h2>
      <div class="featured-meta">
        {% if firstDay and lastDay %}
          {{ firstDay.date | kortdato }} &ndash; {{ (lastDay.endDate or lastDay.date) | kortdato }}
        {% endif %}
        {% if firstDay.location %} &middot; {{ firstDay.location }}{% endif %}
      </div>
      <div class="featured-bottom">
        <span class="featured-days">{{ feat.days | countDays }} dagar</span>
        {% if feat.lastModified | isRecent %}<span class="featured-updated">Oppd. {{ feat.lastModified | kortdato }}</span>{% endif %}
      </div>
    </div>
  </a>
{% endif %}

{# Grid: next 4 posts #}
{% if regularPosts.length > 1 %}
<div class="posts-grid">
  {% for post in regularPosts %}
    {% if loop.index0 >= 1 and loop.index0 <= 4 %}
    {% set firstImage = null %}
    {% for day in post.days %}
      {% if not firstImage and day.images and day.images.length > 0 %}
        {% set firstImage = day.images[0] %}
      {% endif %}
    {% endfor %}
    {% set firstDay = post.days | selectattr("date") | first %}
    {% set lastDay = post.days | selectattr("date") | last %}
    <a href="/{{ post.slug }}/" class="grid-card">
      {% if firstImage %}
      <img src="{{ firstImage.thumbnail }}" alt="{{ post.title }}">
      {% else %}
      <div class="grid-placeholder"></div>
      {% endif %}
      <div class="grid-card-body">
        <div class="grid-head">
          <h3>{{ post.title }}</h3>
          <span class="grid-dates">
            {% if firstDay and lastDay %}{{ firstDay.date | kortdato }} &ndash; {{ (lastDay.endDate or lastDay.date) | kortdato }}{% endif %}
          </span>
        </div>
        <div class="grid-bottom">
          <span class="grid-days">{{ post.days | countDays }} dagar</span>
          {% if post.lastModified | isRecent %}<span class="grid-updated">Oppd. {{ post.lastModified | kortdato }}</span>{% endif %}
        </div>
      </div>
    </a>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{# Tidlegare: remaining regular posts (index 5+) #}
{% if regularPosts.length > 5 %}
<div class="section-divider"><span>Tidlegare</span></div>
<div class="compact-grid">
  {% for post in regularPosts %}
    {% if loop.index0 >= 5 %}
    {% set firstImage = null %}
    {% for day in post.days %}
      {% if not firstImage and day.images and day.images.length > 0 %}
        {% set firstImage = day.images[0] %}
      {% endif %}
    {% endfor %}
    {% set firstDay = post.days | selectattr("date") | first %}
    {% set lastDay = post.days | selectattr("date") | last %}
    <a href="/{{ post.slug }}/" class="compact-card">
      {% if firstImage %}
      <img src="{{ firstImage.thumbnail }}" alt="{{ post.title }}">
      {% else %}
      <div class="compact-placeholder"></div>
      {% endif %}
      <div class="compact-text">
        <h4>{{ post.title }}</h4>
        <span class="compact-meta">
          {% if firstDay and lastDay %}{{ firstDay.date | kortdato }} &ndash; {{ (lastDay.endDate or lastDay.date) | kortdato }}{% endif %}
          &middot; {{ post.days | countDays }} dagar
          {% if post.lastModified | isRecent %} &middot; Oppdatert {{ post.lastModified | kortdato }}{% endif %}
        </span>
      </div>
    </a>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{# Future trips #}
{% if futurePosts.length > 0 %}
<div class="section-divider"><span>Framtidige reiser</span></div>
<div class="compact-grid">
  {% for post in futurePosts %}
  {% set firstDay = post.days | selectattr("date") | first %}
  {% set lastDay = post.days | selectattr("date") | last %}
  <div class="compact-card compact-card-future">
    <div class="compact-placeholder"></div>
    <div class="compact-text">
      <h4>{{ post.title }}</h4>
      <span class="compact-meta">
        {% if firstDay and lastDay %}{{ firstDay.date | kortdato }} &ndash; {{ (lastDay.endDate or lastDay.date) | kortdato }}{% endif %}
      </span>
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}

{# Undervegs #}
{% if undervegsPosts.length > 0 %}
<div class="section-divider"><span>Undervegs</span></div>
<div class="compact-grid compact-grid-single">
  {% for post in undervegsPosts %}
  {% set firstImage = null %}
  {% for day in post.days %}
    {% if not firstImage and day.images and day.images.length > 0 %}
      {% set firstImage = day.images[0] %}
    {% endif %}
  {% endfor %}
  <a href="/{{ post.slug }}/" class="compact-card">
    {% if firstImage %}
    <img src="{{ firstImage.thumbnail }}" alt="{{ post.title }}">
    {% else %}
    <div class="compact-placeholder"></div>
    {% endif %}
    <div class="compact-text">
      <h4>{{ post.title }}</h4>
      <span class="compact-meta">Tankar p&aring; vegen</span>
    </div>
  </a>
  {% endfor %}
</div>
{% endif %}

{% if regularPosts.length == 0 and futurePosts.length == 0 and undervegsPosts.length == 0 %}
<p class="no-posts">Ingen innlegg enno. Koyrer <code>npm run build</code> for &aring; henta innhald.</p>
{% endif %}
