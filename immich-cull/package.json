{
  "name": "immich-cull",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts --immich-api --vertex --port 3737",
    "build": "tsc",
    "dev": "tsx watch src/server.ts --immich-api --vertex --port 3737",
    "start:local": "tsx src/server.ts --local --vertex --port 3737",
    "test": "tsx src/cli/cluster-local.ts --dry-run",
    "lint": "oxlint --deny-warnings src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "typecheck": "tsgo --noEmit",
    "check": "npm run lint && npm run fmt:check && npm run typecheck && npm --prefix web-app run lint && npm --prefix web-app run fmt:check && npm --prefix web-app run check && npm --prefix web-app run test"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "sharp": "^0.33.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
