{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json --fail-on-warnings && tsc -p tsconfig.node.json",
    "lint": "oxlint --deny-warnings src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
