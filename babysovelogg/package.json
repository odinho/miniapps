{
  "name": "babysovelogg",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "git config core.hooksPath babysovelogg/.githooks && (svelte-kit sync || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "test": "bun test ./tests/unit/*.unit.ts ./tests/integration/*.test.ts",
    "test:unit": "bun test ./tests/unit/*.unit.ts",
    "test:e2e": "bunx playwright test",
    "lint": "oxlint --deny-warnings src/ tests/",
    "fmt": "oxfmt --write src/ tests/",
    "fmt:check": "oxfmt --check src/ tests/",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings"
  },
  "dependencies": {
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
