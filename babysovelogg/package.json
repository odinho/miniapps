{
  "name": "babysovelogg",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "build": "node esbuild.config.mjs",
    "dev": "concurrently \"tsx watch server/index.ts\" \"node esbuild.config.mjs --watch\"",
    "test": "npx playwright test",
    "lint": "oxlint src/ server/ tests/ cli/",
    "fmt": "oxfmt --write src/ server/ tests/ cli/ types.ts",
    "fmt:check": "oxfmt --check src/ server/ tests/ cli/ types.ts",
    "typecheck": "tsgo --noEmit",
    "test:unit": "vitest run",
    "check": "tsgo --noEmit && oxlint src/ server/ tests/ cli/ && oxfmt --check src/ server/ tests/ cli/ types.ts",
    "baby": "tsx cli/baby.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "valibot": "^1.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260321.1",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.0.0",
    "vitest": "^4.1.0"
  }
}
