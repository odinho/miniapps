{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": null,
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "oxc/no-map-spread": "off",
    "no-extend-native": "off",
    "no-empty-pattern": "off",
    "no-restricted-imports": ["error", {
      "paths": [{
        "name": "bun:test",
        "importNames": ["mock"],
        "message": "Use dependency injection instead of mocking."
      }]
    }]
  },
  "ignorePatterns": ["dist/", "node_modules/", "src/app.d.ts"]
}
