{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": null,
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "oxc/no-map-spread": "off",
    "no-extend-native": "off",
    "no-empty-pattern": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/"]
}
